---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { ALL_TYPES, type DocType } from '../../lib/types';
import { isVisible, readingMinutes } from '../../lib/utils';

export async function getStaticPaths() {
  const types = ALL_TYPES;
  const paths = await Promise.all(
    types.map(async type => {
      const entries = await getCollection(type, isVisible);
      return entries.map(entry => ({
        params: { slug: entry.id },
        props:  { entry, type },
      }));
    })
  );
  return paths.flat();
}

const { entry, type } = Astro.props as { entry: any; type: DocType };
const { Content, headings } = await render(entry);

const { body } = entry as { body?: string };
const readingTime = readingMinutes(body);
const wordCount   = body ? body.split(/\s+/).filter(Boolean).length : undefined;

const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

// Compute related articles by shared tags + project + type
const allEntries = (await Promise.all(
  ALL_TYPES.map(async t => {
    const entries = await getCollection(t, isVisible);
    return entries.map(e => ({ entry: e, type: t as string }));
  })
)).flat().filter(({ entry: e }) => e.id !== entry.id);

const entryTags: string[] = entry.data.tags ?? [];
const scored = allEntries.map(({ entry: e, type: t }) => {
  const sharedTags = (e.data.tags ?? []).filter((tag: string) => entryTags.includes(tag)).length;
  const sameProject = entry.data.project && e.data.project === entry.data.project ? 2 : 0;
  const sameType = t === type ? 1 : 0;
  return { entry: e, type: t, score: sharedTags * 2 + sameProject + sameType };
}).filter(x => x.score > 0).sort((a, b) => b.score - a.score).slice(0, 4);

type RelatedEntry = { slug: string; title: string; type: string; date: string };
const related: RelatedEntry[] = scored.map(({ entry: e, type: t }) => ({
  slug:  e.id,
  title: e.data.title,
  type:  t,
  date:  e.data.date.toISOString().split('T')[0],
}));

// Chronological prev/next across all published entries (newest first).
// prev -> newer article, next -> older article.
type NavEntry = { slug: string; title: string; type: string };
const chronological = [{ entry, type }, ...allEntries]
  .sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime());
const currentIndex = chronological.findIndex(({ entry: e }) => e.id === entry.id);
const toNav = (item?: { entry: any; type: string }): NavEntry | undefined =>
  item ? { slug: item.entry.id, title: item.entry.data.title, type: item.type } : undefined;
const prev = toNav(chronological[currentIndex - 1]);
const next = toNav(chronological[currentIndex + 1]);
---

<ArticleLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  series={entry.data.series}
  project={entry.data.project}
  readingTime={readingTime}
  wordCount={wordCount}
  type={type}
  headings={tocHeadings}
  related={related}
  prev={prev}
  next={next}
  ogImage={`/og/doc/${entry.id}.png`}
  draft={entry.data.status === 'draft'}
>
  <Content />
</ArticleLayout>
