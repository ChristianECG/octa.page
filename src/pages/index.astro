---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ALL_TYPES } from '../lib/types';
import { readingLabel } from '../lib/utils';

const allEntries = (await Promise.all(
  ALL_TYPES.map(async t => {
    const entries = await getCollection(t, ({ data }) => data.status === 'published');
    return entries.map(e => ({ entry: e, type: t }));
  })
)).flat().sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime());

const year = new Date().getFullYear();
---

<BaseLayout title="Octa" ogImage="/og/index.png">
  <div class="top-strip" id="top-strip">
    <span class="strip-left" id="strip-left">octa · index · {year}</span>
    <span class="strip-right">sort: newest ↓</span>
  </div>

  <div class="hero">
    <h1 class="hero-title">Systems notes &amp; runtime investigations.</h1>
    <p class="hero-deck">
      An engineering lab documenting architecture decisions, runtime research, and performance investigations.
      <strong class="hero-count">{allEntries.length} {allEntries.length === 1 ? 'entry' : 'entries'}</strong> indexed.
    </p>
  </div>

  {allEntries.length === 0 ? (
    <p class="empty">No entries yet. Add markdown files to <code>/content/</code>.</p>
  ) : (
    <div class="table-wrap">
      <table class="entries-table">
        <thead>
          <tr>
            <th class="col-n">#</th>
            <th class="col-date">Date</th>
            <th class="col-title">Title</th>
            <th class="col-type">Type</th>
            <th class="col-read">Read</th>
          </tr>
        </thead>
        <tbody>
          {allEntries.map(({ entry, type }, i) => (
            <tr
              class="entry-row"
              style={`--i: ${i}`}
              data-month={`${entry.data.date.getFullYear()}-${String(entry.data.date.getMonth() + 1).padStart(2, '0')}`}
              data-pinned={entry.data.pinned ? 'true' : 'false'}
            >
              <td class="cell-n">{String(i + 1).padStart(2, '0')}</td>
              <td class="cell-date">
                {entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: '2-digit', day: '2-digit', timeZone: 'UTC' })}
              </td>
              <td class="cell-title">
                <a href={`/doc/${entry.id}`} class="entry-link">{entry.data.title}</a>
              </td>
              <td class="cell-type">
                <a href={`/type/${type}`} class="type-link">{type}</a>
              </td>
              <td class="cell-read">{readingLabel((entry as any).body)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</BaseLayout>

<style>
  .top-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: 28px;
    animation: fade-up 200ms ease-out both;
  }

  .hero {
    animation: fade-up 200ms ease-out both;
    animation-delay: 50ms;
  }

  .table-wrap {
    animation: fade-up 200ms ease-out both;
    animation-delay: 90ms;
  }

  .entry-row {
    animation: fade-up 180ms ease-out both;
    animation-delay: min(calc(var(--i) * 25ms + 110ms), 380ms);
  }

  .strip-left, .strip-right {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .hero {
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--color-rule);
  }

  .hero-title {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: 10px;
  }

  .hero-deck {
    font-size: 13px;
    color: var(--color-ink-2);
    max-width: 60ch;
    margin: 0;
    line-height: 1.6;
  }

  .hero-count {
    font-weight: 500;
    color: var(--color-ink);
  }

  .table-wrap { overflow-x: auto; }

  .entries-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
  }

  .col-n    { width: 44px; }
  .col-date { width: 96px; }
  .col-title {}
  .col-type { width: 120px; }
  .col-read { width: 60px; text-align: right; }

  .entry-row:hover .cell-title,
  .entry-row:hover .cell-date,
  .entry-row:hover .cell-n { color: var(--color-ink); }

  .cell-n {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-mute);
    transition: color 0.12s;
  }

  .cell-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-2);
    white-space: nowrap;
    transition: color 0.12s;
  }

  .cell-title {
    font-size: 13px;
    color: var(--color-ink);
    transition: color 0.12s;
  }

  .entry-link {
    color: inherit;
    text-decoration: none;
  }

  .entry-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  tr { position: relative; }

  .cell-type {
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .type-link {
    color: var(--color-accent);
    text-decoration: none;
    position: relative;
    z-index: 1;
    transition: opacity 0.12s;
  }

  .type-link:hover { opacity: 0.8; }

  .cell-read {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-mute);
    text-align: right;
  }

  .empty {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-mute);
    padding: 24px 0;
  }

  .empty code {
    font-size: 11px;
    background: var(--color-panel);
    border: 1px solid var(--color-rule-2);
    padding: 1px 5px;
  }
</style>

<script>
  const params    = new URLSearchParams(window.location.search);
  const filter    = params.get('filter');
  if (filter) {
    const rows      = document.querySelectorAll<HTMLElement>('.entry-row');
    const stripLeft = document.getElementById('strip-left');

    if (filter === 'month') {
      const now = new Date();
      const ym  = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
      let shown = 0;
      rows.forEach(row => {
        const hide = row.dataset.month !== ym;
        row.style.display = hide ? 'none' : '';
        if (!hide) shown++;
      });
      if (stripLeft) {
        stripLeft.textContent = `octa · this month · ${shown} ${shown === 1 ? 'entry' : 'entries'}`;
      }
    } else if (filter === 'pinned') {
      let shown = 0;
      rows.forEach(row => {
        const hide = row.dataset.pinned !== 'true';
        row.style.display = hide ? 'none' : '';
        if (!hide) shown++;
      });
      if (stripLeft) {
        stripLeft.textContent = `octa · pinned · ${shown} ${shown === 1 ? 'entry' : 'entries'}`;
      }
    }
  }
</script>
