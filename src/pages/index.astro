---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntriesTable from '../components/EntriesTable.astro';
import Pagination from '../components/Pagination.astro';
import { ALL_TYPES } from '../lib/types';
import { isVisible } from '../lib/utils';

const PAGE_SIZE = 20;

const allEntries = (await Promise.all(
  ALL_TYPES.map(async t => {
    const entries = await getCollection(t, isVisible);
    return entries.map(e => ({ entry: e, type: t }));
  })
)).flat().sort((a, b) => b.entry.data.date.getTime() - a.entry.data.date.getTime());

const totalPages = Math.max(1, Math.ceil(allEntries.length / PAGE_SIZE));
const pageEntries = allEntries.slice(0, PAGE_SIZE);

const year = new Date().getFullYear();
---

<BaseLayout title="Octa" ogImage="/og/index.png">
  <div class="top-strip" id="top-strip">
    <span class="strip-left" id="strip-left">octa · index · {year}</span>
    <span class="strip-right">sort: newest ↓</span>
  </div>

  <div class="hero">
    <h1 class="hero-title">Systems notes &amp; runtime investigations.</h1>
    <p class="hero-deck">
      An engineering lab documenting architecture decisions, runtime research, and performance investigations.
      <strong class="hero-count">{allEntries.length} {allEntries.length === 1 ? 'entry' : 'entries'}</strong> indexed.
    </p>
  </div>

  {allEntries.length === 0 ? (
    <p class="empty">No entries yet. Add markdown files to <code>/content/</code>.</p>
  ) : (
    <>
      <EntriesTable entries={pageEntries} offset={0} showType={true} />
      <Pagination currentPage={1} totalPages={totalPages} baseUrl="/" />
    </>
  )}
</BaseLayout>

<style>
  .top-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-rule);
    margin-bottom: 28px;
    animation: fade-up 200ms ease-out both;
  }

  .hero {
    animation: fade-up 200ms ease-out both;
    animation-delay: 50ms;
  }

  .hero {
    margin-bottom: 36px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--color-rule);
  }

  .hero-title {
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 500;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: 10px;
  }

  .hero-deck {
    font-size: 13px;
    color: var(--color-ink-2);
    max-width: 60ch;
    margin: 0;
    line-height: 1.6;
  }

  .hero-count {
    font-weight: 500;
    color: var(--color-ink);
  }

  .strip-left, .strip-right {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-mute);
  }

  .empty {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-mute);
    padding: 24px 0;
  }

  .empty code {
    font-size: 11px;
    background: var(--color-panel);
    border: 1px solid var(--color-rule-2);
    padding: 1px 5px;
  }
</style>
